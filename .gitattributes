# Auto-detect text files, normalize to LF on commit
* text=auto

# Source code — always LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.astro text eol=lf
*.jsonc text eol=lf
*.plist text eol=lf
*.td text eol=lf

# Shell scripts — always LF (won't run with CRLF)
*.sh text eol=lf
*.bash text eol=lf

# Binary files — don't touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.lockb binary
